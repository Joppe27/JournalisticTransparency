@if (!Invasive)
{
    <TrackedComponent OnTrackedElementCreated="@_trackedComponentCreatedCallback" @ref="_trackedAccordionToggle" T="AccordionToggle" Attributes="@Attributes" Name="@Name" Owner="@Owner"/>
}

@if (Invasive)
{
    <Tooltip Text="Klik hier voor meer info!" AlwaysActive="@true" Placement="TooltipPlacement.Right" Inline="@true" AppendTo="parent">
        <TrackedComponent OnTrackedElementCreated="@_trackedComponentCreatedCallback" @ref="_trackedAccordionToggle" T="AccordionToggle" Attributes="@Attributes" Name="@Name" Owner="@Owner"/>
    </Tooltip>
}


@code {
    [CascadingParameter(Name = "ComponentCreatedCallback")] public EventCallback<ITracked> OnTrackedComponentCreated { get; set; }
    
    [Parameter] [EditorRequired] public bool Invasive { get; set; }
    [Parameter] [EditorRequired] public required string Name { get; init; }
    [Parameter] [EditorRequired] public required IComponent Owner { get; init; }
    [Parameter] public Dictionary<string, object>? Attributes { get; set; }
    
    private TrackedComponent<AccordionToggle> _trackedAccordionToggle = null!;
    
    private EventCallback<ITracked> _trackedComponentCreatedCallback;

    private bool _initialized;

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (_initialized)
            return;

        _trackedComponentCreatedCallback = EventCallback.Factory.Create<ITracked>(this, _ => InitializeTrackedComponent());
        _initialized = true;
    }

    private void InitializeTrackedComponent()
    {
        var toggle = (_trackedAccordionToggle.Object as AccordionToggle)!;
        
        _trackedAccordionToggle.AddNestedCallback(nameof(AccordionToggle.Clicked), new EventCallbackWrapper<MouseEventArgs>(EventCallback.Factory.Create(this, (MouseEventArgs _) =>
        {
            _trackedAccordionToggle.Interactions.Add(new TrackedInteraction(!toggle.AccordionItemVisible ? Interaction.Opened : Interaction.Closed, _trackedAccordionToggle.SessionTimer.Elapsed));
        })));

        OnTrackedComponentCreated.InvokeAsync(_trackedAccordionToggle);
        
        StateHasChanged();
    }
}