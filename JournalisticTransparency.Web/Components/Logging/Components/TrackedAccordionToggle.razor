@inject TrackingService TrackingService

@if (!Invasive)
{
    <TrackedComponent @ref="_trackedAccordionToggle"
                      T="AccordionToggle" Attributes="@Attributes" Name="@Name" Owner="@Owner"/>
}

@if (Invasive)
{
    <Tooltip Text="Klik hier voor meer info!" AlwaysActive="@true" Placement="TooltipPlacement.Right" Inline="@true"
             AppendTo="parent">
        <TrackedComponent @ref="_trackedAccordionToggle"
                          T="AccordionToggle" Attributes="@Attributes" Name="@Name" Owner="@Owner"/>
    </Tooltip>
}


@code {
    [Parameter] [EditorRequired] public bool Invasive { get; set; }
    [Parameter] [EditorRequired] public required string Name { get; init; }
    [Parameter] [EditorRequired] public required IComponent Owner { get; init; }
    [Parameter] public Dictionary<string, object>? Attributes { get; set; }

    private TrackedComponent<AccordionToggle> _trackedAccordionToggle = null!;

    private bool _initialized;

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (_initialized)
            return;

        TrackingService.OnTrackedElementCreated += InitializeTrackedComponent;
        _initialized = true;
    }

    private void InitializeTrackedComponent(ITracked trackedElement)
    {
        if (trackedElement != _trackedAccordionToggle)
            return;
        
        var toggle = (_trackedAccordionToggle.Object as AccordionToggle)!;

        _trackedAccordionToggle.AddNestedCallback(nameof(AccordionToggle.Clicked), new EventCallbackWrapper<MouseEventArgs>(EventCallback.Factory.Create(this, (MouseEventArgs _) => { _trackedAccordionToggle.Interactions.Add(new TrackedInteraction(!toggle.AccordionItemVisible ? Interaction.Opened : Interaction.Closed, _trackedAccordionToggle.SessionTimer.Elapsed)); })));

        StateHasChanged();
    }

}