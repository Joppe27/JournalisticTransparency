@page "/article"
@using System.Diagnostics
@using System.Globalization
@using System.Net.Http.Headers
@using System.Text.Json
@using System.Text.Json.Serialization
@using Azure.Storage.Blobs
@using JournalisticTransparency.Web.Components.Articles
@using JournalisticTransparency.Web.Components.Layout
@using JournalisticTransparency.Web.Components.Logging
@using JournalisticTransparency.Web.Components.Logging.Objects
@using Microsoft.AspNetCore.WebUtilities
@inject IJSRuntime JS
@inject TrackingService TrackingService
@inject NavigationManager NavigationManager

<PageTitle>Artikel experiment</PageTitle>

<Layout>
    <SiteHeader DisplayToast="@(() => _toastVisible = true)"/>
    <Layout Sider Width="Width.Is75.OnDesktop.Is100.OnMobile" Margin="Margin.IsAuto.OnX">
        <LayoutSider Display="Display.Block.OnDesktop.None.OnMobile" Background="Background.White">
            <LayoutSiderContent Display="Display.Flex.Column" Height="Height.Is100"
                                Padding="Padding.Is3.FromStart.Is5.OnY.Is5.FromEnd"
                                Style="border-right: 1px solid rgb(224,224,224)">
                <SiteSectionCard DisplayToast="@(() => _toastVisible = true)"/>
                <Div Flex="Flex.Grow.Is1"></Div>
                <ShareCard DisplayFunctionDisabledToast="@(() => _toastVisible = true)"/>
            </LayoutSiderContent>
        </LayoutSider>
        <Layout Style="scrollbar-width: thin">
            <LayoutContent>
                <Row Padding="Padding.Is5.OnY.Is3.OnX" Height="Height.Is100">
                    <Column ColumnSize="ColumnSize.Is9.OnDesktop.IsFull.OnMobile" Padding="Padding.Is5.OnX">
                        <ArticleHeader/>
                        <DynamicComponent Type="_articleContentType" Parameters="_articleContentParameters"/>
                        <Div Flex="Flex.JustifyContent.End">
                            <Button Display="Display.None.OnDesktop.Block.OnMobile"
                                    Clicked="@(() => _confirmSurveyModal.Show())" Margin="Margin.Is5.FromTop">
                                <Text Style="white-space: pre">Naar de enquête</Text>
                                <Icon Name="IconName.ArrowRight" IconSize="IconSize.Large"/>
                            </Button>
                        </Div>
                    </Column>
                    <Column Display="Display.Block.OnDesktop.None.OnMobile" ColumnSize="ColumnSize.Is3"
                            Padding="Padding.Is3.FromEnd.Is0.FromStart">
                        <Div Flex="Flex.Column" Height="Height.Is100">
                            <MostReadCard DisplayToast="@(() => _toastVisible = true)"/>
                            <Div Flex="Flex.Grow.Is1"></Div>
                            <Div Flex="Flex.JustifyContent.Center">
                                <Button Flex="Flex.Column.Grow.Is1" Width="Width.Is100" style="overflow: hidden;" Clicked="@(() => _confirmSurveyModal.Show())">
                                    <Text TextSize="TextSize.Large" Style="white-space: pre" Margin="Margin.Is3.OnY">Naar de enquête</Text>
                                    <Icon Name="IconName.ArrowRight" IconSize="IconSize.x3"/>
                                </Button>
                            </Div>
                        </Div>
                    </Column>
                </Row>
            </LayoutContent>
        </Layout>
    </Layout>
</Layout>

<Toaster>
    <Toast @bind-Visible="@_toastVisible" Margin="Margin.Is5">
        <ToastBody Padding="Padding.Is0" Flex="Flex.AlignItems.Center" Gap="Gap.Is2">
            <Strong>Die functie is uitgeschakeld tijdens het experiment.</Strong>
            <CloseButton/>
        </ToastBody>
    </Toast>
</Toaster>

<Modal @ref="_confirmSurveyModal">
    <ModalContent Centered>
        <ModalHeader>
            <ModalTitle>Doorgaan naar de enquête?</ModalTitle>
        </ModalHeader>
        <ModalBody>
            <Text>U kunt het artikel hierna niet meer lezen. Dit kan niet ongedaan gemaakt worden.</Text>
        </ModalBody>
        <ModalFooter Margin="Margin.Is3.FromTop">
            <Button Color="Color.Secondary" Clicked="@(() => _confirmSurveyModal.Close(CloseReason.UserClosing))">
                Annuleren
            </Button>
            <Button Color="Color.Primary" Clicked="EndArticleSession" Loading="_loading">Doorgaan</Button>
        </ModalFooter>
    </ModalContent>
    
    <Toaster>
        <Toast @bind-Visible="@_errorToastVisible" Autohide="false">
            <ToastBody Padding="Padding.Is0" Flex="Flex.AlignItems.Center" Gap="Gap.Is2">
                <Strong>Fout tijdens uploaden gegevens: @_errorToastMessage</Strong>
                <CloseButton/>
            </ToastBody>
        </Toast>
    </Toaster>
</Modal>

@if (Debugging is true)
{
    <DebugOverlay DebuggerEntries="@_trackedComponents"/>
}


@code {
    [Inject(Key = "ParticipantId")] private string ParticipantId { get; set; } = null!;
    [Inject(Key = "ApiHttpClient")] private HttpClient ApiHttpClient { get; set; } = null!;
    [Inject(Key = "SessionTimer")] private Stopwatch SessionTimer { get; set; } = null!;

    [Parameter] [SupplyParameterFromQuery] public bool? Debugging { get; set; }
    [Parameter] [SupplyParameterFromQuery] public int TransparencyType { get; set; } //https://learn.microsoft.com/en-us/aspnet/core/blazor/fundamentals/navigation?view=aspnetcore-10.0&utm_source=chatgpt.com#query-strings

    private Dictionary<string, object> _articleContentParameters = null!;

    private Modal _confirmSurveyModal = null!;
    private bool _toastVisible;
    private bool _errorToastVisible;
    private string _errorToastMessage = "";
    private Type _articleContentType = null!;

    private readonly List<ITracked> _trackedComponents = new();
    private TrackedStopwatch _trackedReadTime = null!;

    private bool _initialized;

    private bool _loading;

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (!_initialized)
        {
            _articleContentType = ArticleContentFactory.GetComponentType((TransparencyType)TransparencyType);
            _articleContentParameters = new() { [nameof(ArticleContent.DisplayFunctionDisabledToast)] = EventCallback.Factory.Create(this, () => _toastVisible = true) };

            TrackingService.OnTrackedElementCreated += AddToList;
            
            if (Debugging is true)
                TrackingService.OnInteractionsChanged += UpdateDebugger;

            _trackedReadTime = new(TrackingService, SessionTimer) { Name = "globale leestijd", Owner = this };
            _trackedReadTime.Start();

            _initialized = true;
        }
    }

    protected override Task OnInitializedAsync()
    {
        JS.InvokeVoidAsync("unload.enableBeforeUnload");

        return base.OnInitializedAsync();
    }

    private void AddToList(ITracked trackedComponent)
    {
        if (!_trackedComponents.Contains(trackedComponent))
            _trackedComponents.Add(trackedComponent);
    }

    private void UpdateDebugger(ITracked _) => StateHasChanged();

    private async Task EndArticleSession()
    {
        _trackedReadTime.Stop();

        _loading = true;

        var options = new JsonSerializerOptions()
        {
            WriteIndented = true,
            Converters = { new JsonStringEnumConverter() },
        };

        try
        {
            var httpResponse = await ApiHttpClient.GetAsync("GetSAS");

            httpResponse.EnsureSuccessStatusCode();

            var blobContainerString = await httpResponse.Content.ReadFromJsonAsync<string>() ?? throw new InvalidOperationException();
            var blobContainerUri = new Uri(blobContainerString);
        
            var blobContainerClient = new BlobContainerClient(blobContainerUri);
            
            await blobContainerClient.UploadBlobAsync($"{TransparencyType}/{ParticipantId}.json", BinaryData.FromObjectAsJson(_trackedComponents, options),
                CancellationToken.None);
        }
        catch (Exception e)
        {
            _loading = false;
            _errorToastMessage = e.Message;
            _errorToastVisible = true;
            return;
        }

        await JS.InvokeVoidAsync("unload.disableBeforeUnload");

        const string qualtricsBaseUrl = "https://vub.fra1.qualtrics.com/jfe/form/SV_8vt1Gi1ivxvfcua";
        var querys = new Dictionary<string, string?>()
        {
            { "ParticipantID", ParticipantId },
        };

        var qualtricsUrl = QueryHelpers.AddQueryString(qualtricsBaseUrl, querys);

        NavigationManager.NavigateTo(qualtricsUrl);
    }
}